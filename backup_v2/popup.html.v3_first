<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <title>Nichinoken Test Data Extractor</title>
    <link rel="stylesheet" href="popup.css">
</head>
<body>
    <div class="container">
        <header class="app-header">
            <h1>&#x1F4CB; 日能研テストデータ抽出</h1>
            <span class="version-badge">v3.0</span>
        </header>

        <!-- ① ページ検出 & データ抽出 -->
        <div id="statusArea" class="card card-primary">
            <div class="card-header">
                <h2>データ抽出</h2>
                <span id="pageTypeBadge" class="badge badge-neutral">検出中...</span>
            </div>
            <p id="pageStatus" class="status-text">ページを確認しています...</p>

            <!-- 抽出結果サマリー -->
            <div id="extractResult" style="display: none;">
                <div class="result-grid">
                    <div class="result-item">
                        <span class="result-label">テスト名</span>
                        <span id="lblTestName" class="result-value"></span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">実施日</span>
                        <span id="lblExamDate" class="result-value"></span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">教科</span>
                        <span id="lblSubjects" class="result-value"></span>
                    </div>
                    <div class="result-item">
                        <span class="result-label">成績集計</span>
                        <span id="lblSummaryStatus" class="result-value"></span>
                    </div>
                </div>

                <div class="actions-main">
                    <button id="btnExtractAndDownload" class="btn primary large">
                        &#x1F4E5; JSONを抽出してダウンロード
                    </button>
                    <button id="btnExtractAndSave" class="btn outline">
                        &#x1F4BE; ストレージに保存
                    </button>
                </div>
            </div>

            <details id="debugSection" style="display: none; margin-top: 12px;">
                <summary class="debug-summary">&#x1F50D; 診断ログ</summary>
                <pre id="debugLog" class="debug-log"></pre>
                <button id="btnCopyLog" class="btn small outline" style="margin-top: 6px;">&#x1F4CB; ログをコピー</button>
            </details>
        </div>

        <!-- ② 保存データ管理 -->
        <div class="card">
            <div class="card-header">
                <h2>保存データ管理</h2>
                <span id="lblStoredCount" class="badge badge-info">0件</span>
            </div>
            <p class="hint">期間: <span id="lblDateRange">--</span></p>

            <div class="actions">
                <button id="btnDownloadAll" class="btn outline">&#x1F4E5; 全データJSON</button>
                <button id="btnMigrate" class="btn outline" style="display:none;">&#x1F504; v2→v3移行</button>
                <button id="btnClear" class="btn danger outline">&#x1F5D1; 全クリア</button>
            </div>

            <div class="import-section">
                <p class="hint">JSONから復元:</p>
                <input type="file" id="fileImport" accept=".json">
            </div>
        </div>

        <!-- ③ JSONプレビュー -->
        <div id="previewCard" class="card" style="display: none;">
            <div class="card-header">
                <h2>JSONプレビュー</h2>
                <div class="preview-actions">
                    <button id="btnCopyJson" class="btn small outline">&#x1F4CB; コピー</button>
                    <button id="btnClosePreview" class="btn small outline">✕ 閉じる</button>
                </div>
            </div>
            <pre id="jsonPreview" class="json-preview"></pre>
        </div>
    </div>
    <script src="popup.js"></script>
</body>
</html>
